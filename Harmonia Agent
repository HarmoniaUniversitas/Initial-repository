    psi = 0.5 # Start at neutral coherence
    
    for t in range(MAX_STEPS):
        grid, match, error = solver.step(psi)
        
        # Calculate PSI using the metrics.py formula
        # Note: action_entropy comes from the solver's policy distribution
        psi = compute_psi(match, error, action_entropy=0.1) 
        
